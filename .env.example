# --- Database (Turso / libsql) ---
# Local dev: a file URL works with no auth token.
# Production (Turso): create a DB at https://turso.tech and use its URL + token:
#   TURSO_DATABASE_URL=libsql://<your-db>-<org>.turso.io
#   TURSO_AUTH_TOKEN=<token from `turso db tokens create`>
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# --- Auth ---
# The passcode you type to unlock the app. Change this before deploying.
# The session cookie is derived from it, so changing it logs every device out.
APP_PASSCODE=change-me

# --- AI coach (optional) ---
# Powers the in-app coach. Optional: without any key the coach degrades
# gracefully and stays disabled. Put the real value(s) in .env.local (never
# commit). Set ONE provider's key — the coach auto-detects which to use in the
# order anthropic → openrouter → gemini → openai → custom, or pin one with
# COACH_PROVIDER. COACH_MODEL overrides the per-provider default model.

# Anthropic (default) — https://console.anthropic.com  · default model claude-sonnet-4-6
ANTHROPIC_API_KEY=

# OpenRouter (one key, many models incl. Claude/Gemini/GPT) — https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# Google Gemini (OpenAI-compatible endpoint) — https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Pin a provider and/or model (optional):
# COACH_PROVIDER=openrouter        # anthropic | openrouter | gemini | openai | custom
# COACH_MODEL=anthropic/claude-sonnet-4.6

# Custom OpenAI-compatible gateway (needs all three):
# COACH_BASE_URL=https://your-gateway/v1
# COACH_API_KEY=...
# COACH_MODEL=your-model
